  "devDependencies": {
    "@hono/node-server": "2.0.5",
    "@hono/vite-build": "1.11.1",
    "@hono/vite-dev-server": "0.26.0",
    "@tailwindcss/postcss": "4.3.1",
    "@tailwindcss/typography": "0.5.20",
    "@tailwindcss/vite": "4.3.1",
    "@types/node": "25.9.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "fallow": "2.97.0",
    "lefthook": "2.1.9",
    "oxfmt": "0.55.0",
    "oxlint": "1.70.0",
