{
  "name": "remotion-voisona-example",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "setup": "pnpm approve-builds esbuild sharp && pnpm install",
    "dev": "vite",
    "build": "vite build && vite build --mode server",
    "hooks:install": "lefthook install",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "start": "node dist/index.js",
    "render": "remotion render src/remotion/core/runtime.ts RemotionVoisonaExample out/latest.mp4",
    "test": "vitest run"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@hookform/resolvers": "^5.4.0",
    "@remotion/cli": "4.0.443",
    "@remotion/player": "4.0.443",
    "@remotion/studio": "4.0.443",
    "@tiptap/react": "^2.26.4",
    "@tiptap/starter-kit": "^2.26.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hono": "^4.8.12",
    "lucide-react": "^1.16.0",
    "mediabunny": "1.39.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.76.1",
    "react-hotkeys-hook": "^5.2.1",
    "remotion": "4.0.443",
    "swr": "^2.3.6",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "uuid": "^14.0.0",
    "vite-ssr-components": "^0.6.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@hono/node-server": "^1.19.4",
    "@hono/vite-build": "^1.7.0",
    "@hono/vite-dev-server": "^0.19.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "24.12.0",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^5.1.0",
    "lefthook": "2.1.6",
    "oxfmt": "0.47.0",
    "oxlint": "1.62.0",
    "shadcn": "^4.8.0",
    "tailwindcss": "^4.3.0",
    "typescript": "5.9.3",
    "vite": "^7.1.12",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
