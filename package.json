    "@tiptap/react": "3.27.0",
    "@tiptap/starter-kit": "3.27.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "hono": "4.12.25",
    "lucide-react": "1.20.0",
    "mediabunny": "1.48.0",
    "next-themes": "0.4.6",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "7.79.0",
    "react-hotkeys-hook": "5.3.2",
    "remotion": "4.0.478",
    "sonner": "2.0.7",
    "swr": "2.4.1",
    "tailwind-merge": "3.6.0",
